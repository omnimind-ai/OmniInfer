#!/bin/sh

set -eu

SCRIPT_PATH="$0"
case "$SCRIPT_PATH" in
    /*) ;;
    *) SCRIPT_PATH="$(pwd)/$SCRIPT_PATH" ;;
esac

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"

is_android=0
if command -v getprop >/dev/null 2>&1; then
    if getprop ro.build.version.release >/dev/null 2>&1; then
        is_android=1
    fi
fi

if [ "$is_android" -eq 1 ]; then
    echo "The repo-root desktop CLI is not the Android runtime. Use the root android/ Gradle module instead." >&2
    exit 1
fi

rust_cli="$SCRIPT_DIR/target/debug/omniinfer-rs"

if [ -x "$rust_cli" ]; then
    exec "$rust_cli" "$@"
fi

echo "Rust OmniInfer CLI was not found at $rust_cli. Run: cargo build -p omniinfer-cli" >&2
exit 1
